# ============================================================
# ENVIRONMENT VARIABLES
# Copy this file to .env and fill in all values.
# Never commit .env to version control.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database ---
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/tactical_game

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_BYTE_HEX_STRING
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_BYTE_HEX_STRING

# Access tokens expire quickly; refresh tokens live longer.
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# --- Expo Push Notifications ---
# Leave blank during local development (notifications will be logged instead)
EXPO_ACCESS_TOKEN=

# --- Rate Limiting ---
# Max requests per window per IP (for auth endpoints)
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=900000

# Max requests per window per IP (for general API)
RATE_LIMIT_API_MAX=300
RATE_LIMIT_API_WINDOW_MS=60000

# --- Turn Deadline ---
# How many hours a player has to submit their turn before auto-forfeit
TURN_DEADLINE_HOURS=72

# --- Matchmaking ---
# How often the matchmaking job runs (seconds)
MATCHMAKING_INTERVAL_SECONDS=30
# Starting Elo search range
MATCHMAKING_INITIAL_RANGE=100
# How much range expands each interval
MATCHMAKING_RANGE_INCREMENT=25
